# Build artifacts
/build/
/output/

# Test coverage
coverage.out
coverage.html

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# Compiled ssg binary (never commit build artifacts — see #73 Binary-Artifacts)
/ssg
/ssg-*

# Logs
*.log

# Temporary files
tmp/
temp/

# Content (except test-content for CI)
content/*
!content/test-content/

# Archive deployments (--zip / --targz / --tarxz)
*.zip
*.tar.xz

# Distribution/Packaging
/dist/
*.deb
*.rpm
*.snap
*.tar.gz
/.claude/
/.claude/*
/.agent/
/.agent/*
# Downloaded themes (created by --online-theme)
templates/gohugo-*/
templates/hugo-*/

# Audit reports (local only)
/audit/

# Image-processing cache (v1.8.3)
.ssg-cache/

# Example project build artifacts
examples/*/output/

# Documentation site built by `make site` from docs/ (.ssg.yaml)
.site/

# Local wrangler dev artifacts (miniflare state, generated config)
.wrangler/
/wrangler.toml
