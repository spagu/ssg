# SSG Configuration File
# Copy this to .ssg.yaml in your project root

# Required: Content source, template, and domain
source: "my-content"
template: "krowy"
domain: "example.com"

# Paths (optional, these are defaults)
content_dir: "content"
templates_dir: "templates"
output_dir: "output"
static_dir: "static"   # Copied verbatim to output (all files & subdirs). Missing dir = no-op

# Server & Development
http: false          # Start built-in HTTP server
host: "127.0.0.1"    # Dev server bind address (use 0.0.0.0 to expose on all interfaces)
port: 8888           # HTTP server port
watch: false         # Watch for changes and rebuild
clean: false         # Clean output before build

# Public Server Hardening (opt-in; all off by default)
tls_cert: ""         # Path to a PEM certificate (with tls_key → HTTPS + HTTP/2)
tls_key: ""          # Path to the matching PEM private key
tls_auto: false      # Automatic Let's Encrypt certificates (needs tls_domain, port 443)
tls_domain: ""       # Domain(s) for autocert, comma-separated
http3: false         # Serve HTTP/3 (QUIC) alongside HTTP/2 (requires TLS)
gzip: false          # gzip-compress responses when the client accepts it
max_conns: 0         # Cap simultaneous connections (0 = unlimited)
mem_limit: ""        # Runtime GC soft memory target, e.g. "512MiB", "1GiB"

# Output Control
sitemap_off: false   # Disable sitemap.xml generation
robots_off: false    # Disable robots.txt generation
pretty_html: false   # Prettify HTML (remove all blank lines)
relative_links: false # Convert absolute URLs to relative links
post_url_format: ""  # Post URL format: "date" (default: /YYYY/MM/DD/slug/) or "slug" (/slug/)
page_format: ""      # Page output: "directory" (slug/index.html), "flat" (slug.html), "both"
minify_all: false    # Minify HTML, CSS, and JS
minify_html: false   # Minify only HTML
minify_css: false    # Minify only CSS
minify_js: false     # Minify only JS
sourcemap: false     # Emit v3 source maps (*.js.map/*.css.map) for minified JS/CSS
                     # (minification becomes line-preserving so mappings are exact)
fingerprint: false   # Content-hash CSS/JS → name.<hash8>.ext + assets-manifest.json,
                     # rewriting references in HTML and CSS (immutable caching)

# SEO & Migration
lastmod_from_git: false   # sitemap <lastmod> from each file's last git commit (fallback: modified/date)
# permalinks:               # Configurable URL patterns per content type (default: date/slug)
#   post: "/:year/:month/:slug/"   # tokens: :year :month :day :slug :category
#   page: "/:slug/"
# Per-page frontmatter: aliases: [/old/path/] → meta-refresh + canonical redirect stubs

# Blog
paginate: 0          # Posts per index page; 0 disables pagination (else adds /page/N/ + .Pager)

# Authoring
math: false          # Detect $$…$$ / ```math and inject KaTeX only on pages that use it (opt-in)
sanitize_html: false # Sanitize raw HTML in markdown via bluemonday UGC policy (FE-005)
highlight: false     # Syntax highlighting for code blocks via Chroma
highlight_style: "github"  # Chroma style (e.g. github, monokai, dracula)
toc: false           # Expose .TOC (table of contents); [toc] in content always expands
toc_depth: 3         # Max heading level included in the TOC

# Blog feeds & archives
feed: false          # Generate Atom feed.xml at root + per category/tag
feed_items: 20       # Max items per feed
feed_full_content: false  # true = full rendered content, false = summary/excerpt

# SEO
seo_off: false       # Disable the generator-level OG/Twitter/JSON-LD injection
check_links: ""      # "" (off), "warn" (report dead internal links), "strict" (fail build)

# Asset bundling — concatenate groups before minify/fingerprint (reference the bundle in templates)
# bundles:
#   app.css: ["reset.css", "layout.css", "theme.css"]
#   app.js:  ["vendor.js", "main.js"]

# Output formats & search
outputs: ["html"]    # add "json" for a headless index.json next to each index.html
search_index: false  # Emit search-index.json (title/url/tags/excerpt/text) for client-side search

# Data files — data/*.yaml|*.json exposed to templates as {{.Data.*}} (nested by subdir)
data_dir: "data"

# i18n / multilingual — language-prefixed output (/en/…) + hreflang alternates
# languages: ["pl", "en"]
# default_language: "pl"     # default is NOT prefixed; other languages get /<lang>/…

# Build hooks — exec commands per lifecycle phase. TRUSTED LOCAL CONFIG ONLY: argv-split
# (no shell), time-limited. Env: SSG_OUTPUT_DIR, SSG_PHASE, SSG_PAGE_PATH (post_page).
# hooks:
#   pre_build:  ["./scripts/prepare.sh"]
#   post_build: ["./scripts/deploy.sh"]
#   post_page:  []

# Template Engine
engine: "go"         # Options: go, pongo2, mustache, handlebars
# online_theme: ""   # Download theme from URL (GitHub, GitLab, or direct ZIP)
                     # Example: https://github.com/janraasch/hugo-bearblog

# Image Processing (requires cwebp installed)
webp: false          # Convert images to WebP
webp_quality: 60     # Quality 1-100 (lower = smaller file)
reconvert_images: false  # Force reconvert even if WebP already exists
# image_sizes: [480, 960, 1600]  # Responsive widths (px): emit WebP variants + <img srcset> (no upscaling)
# image_sizes_attr: "100vw"      # Value of the generated sizes attribute

# Deployment
zip: false           # Create ZIP archive of the output tree (Cloudflare Pages ready)
targz: false         # Create gzip-compressed tarball (.tar.gz) of the output tree
tarxz: false         # Create xz-compressed tarball (.tar.xz) of the output tree

# Native publish (secrets ALWAYS come from the environment, never this file)
deploy: ""           # "" (off) | cloudflare | github-pages | netlify | vercel | ftp | sftp
deploy_project: ""   # Pages/site/project name (cloudflare, netlify, vercel)
deploy_branch: ""    # Target branch (cloudflare, github-pages; default gh-pages)
deploy_target: ""    # ftp://user@host/path, sftp://user@host/path, or a git remote URL
# Required env per provider:
#   cloudflare   → CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID
#   github-pages → GITHUB_TOKEN (https remotes) or an SSH key
#   netlify      → NETLIFY_AUTH_TOKEN (site via deploy_project or NETLIFY_SITE_ID)
#   vercel       → VERCEL_TOKEN, VERCEL_ORG_ID (project via deploy_project)
#   ftp          → FTP_USERNAME, FTP_PASSWORD
#   sftp         → SSH_USERNAME, SSH_PASSWORD or SSH_KEY_FILE (host in known_hosts)

# Shortcodes - reusable content snippets, use {{name}} in markdown
# Template file is REQUIRED - create your own templates in the theme folder
# shortcode_brackets: false  # Also match [name] syntax (WordPress-style, default: false)
# shortcodes:
#   - name: "thunderpick"          # Use as {{thunderpick}} in content
#     template: "shortcodes/banner.html"  # REQUIRED: template file in theme
#     type: "banner"               # Available as {{.Type}} in template (for conditionals)
#     title: "Thunderpick"         # Available as {{.Title}} in template
#     text: "100% up to $1000"     # Available as {{.Text}} in template
#     url: "https://example.com"   # Available as {{.Url}} in template
#     logo: "/images/logo.png"     # Available as {{.Logo}} in template
#     legal: "18+. T&Cs Apply."    # Available as {{.Legal}} in template
#     ranking: 4.5                 # Available as {{.Ranking}} in template (e.g., 3 or 3.5)
#     tags: ["game", "public"]     # Available as {{.Tags}} in template (array of strings)
#     data:                        # Available as {{.Data.key}} in template
#       color: "blue"
#       size: "large"

# Content directory structure (optional, these are defaults)
# pages_path: "pages"   # Subdirectory inside source for static pages (default: "pages")
# posts_path: "posts"   # Subdirectory inside source for blog posts  (default: "posts")
# rewrite_md_links: false      # Rewrite relative .md links to final output URLs (opt-in)
# preserve_slug_case: false    # Keep original casing in slugs/URLs (default: lowercase)

# Variables - custom variables available in all templates as {{.Vars.key}}
# and exported as environment variables with SSG_ prefix (e.g. SSG_GTM).
# Values starting with $ are resolved from the current OS environment.
# variables:
#   gtm: "GTM-XXXXXXX"          # Use as {{.Vars.gtm}} in templates, exported as SSG_GTM
#   analytics_id: "$GA_ID"       # Resolved from env var $GA_ID at build time
#   api:
#     endpoint: "https://api.example.com"  # Nested: {{.Vars.api.endpoint}}, exported as SSG_API_ENDPOINT

# Other
quiet: false         # Suppress output (only exit codes)
